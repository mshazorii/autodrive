{
  "name": "AutoDrive Dealer Portal",
  "short_name": "AutoDrive",
  "description": "Real-time lead management and CRM for automotive dealers",
  "start_url": "/dealer/?source=pwa",
  "scope": "/dealer/",
  "display": "standalone",
  "orientation": "any",
  "theme_color": "#1a56db",
  "background_color": "#f4f5f9",
  "lang": "en",
  "categories": ["business", "productivity"],

  "icons": [
    { "src": "/icons/icon-72.png",   "sizes": "72x72",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-96.png",   "sizes": "96x96",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-128.png",  "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-144.png",  "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-152.png",  "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png",  "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "/icons/icon-384.png",  "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png",  "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],

  "screenshots": [
    {
      "src": "/screenshots/crm-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "CRM lead pipeline on mobile"
    },
    {
      "src": "/screenshots/dashboard-desktop.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Analytics dashboard on desktop"
    }
  ],

  "shortcuts": [
    {
      "name": "CRM",
      "short_name": "CRM",
      "description": "Open lead priority queue",
      "url": "/dealer/?page=crm&source=shortcut",
      "icons": [{ "src": "/icons/shortcut-crm.png", "sizes": "96x96" }]
    },
    {
      "name": "New Lead",
      "short_name": "Leads",
      "description": "View latest leads",
      "url": "/dealer/?page=leads&source=shortcut",
      "icons": [{ "src": "/icons/shortcut-leads.png", "sizes": "96x96" }]
    }
  ],

  "share_target": {
    "action": "/dealer/share-lead",
    "method": "POST",
    "enctype": "application/x-www-form-urlencoded",
    "params": { "title": "title", "text": "text", "url": "url" }
  },

  "related_applications": [],
  "prefer_related_applications": false
